# Copy to .env.local and fill in. Never commit .env.local — it holds live keys.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Project Settings → API. The service-role key bypasses RLS: server-side only,
# never expose it to the browser or prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site (required) ───────────────────────────────────────────────────────────
# Canonical public origin. Drives metadataBase, robots.txt and sitemap.xml, so
# a wrong value here publishes wrong canonical URLs to search engines.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin login (required) ────────────────────────────────────────────────────
# The email must also exist in the `admin_users` table. Cookie secrets sign the
# session cookie — use a distinct random string of 32+ chars per environment.
# See SECURITY note in the repo: the password vars are currently compared as
# plaintext, not as scrypt hashes.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_COOKIE_SECRET=

# ── Super-admin portal (required) ─────────────────────────────────────────────
# Separate login that manages the admin allowlist. Keep these different from
# the ADMIN_* values above.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD_HASH=
SUPER_ADMIN_COOKIE_SECRET=

# ── RAG assistant (optional) ──────────────────────────────────────────────────
# Powers the chat widget and the databank → vector store sync. Unset falls back
# to the shared hosted service. RAG_API_KEY is only needed when the RAG service
# itself sets SERVICE_API_KEY.
RAG_API_URL=
RAG_API_KEY=

# ── Transactional email (optional) ────────────────────────────────────────────
# Unset disables sending; status-change notifications are skipped silently.
DOTNET_MAILER_URL=
INTERNAL_MAILER_SECRET=

# ── Analytics (optional) ──────────────────────────────────────────────────────
# GA4 measurement ID (G-XXXXXXXXXX). Unset skips GA entirely, which keeps local
# dev and previews out of the production property.
NEXT_PUBLIC_GA_ID=

# ── Tooling (optional) ────────────────────────────────────────────────────────
# Postgres connection string for scripts/run-migration.ts. Supabase → Project
# Settings → Database → Connection string → URI. DATABASE_URL and POSTGRES_URL
# are accepted as fallbacks so provider-injected vars work unchanged.
SUPABASE_DB_URL=

# Prefills the application form in dev. Never set in production.
DEBUG_FORM_PREFILL=

# Target origin for the Playwright / API integration suites.
BASE_URL=
